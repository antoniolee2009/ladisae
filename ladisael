    contra:`Como advogado ${posicao} na área de ${area}, antecipe os argumentos contrários e responda:\n\n${caso}`,
    jurisprudencia:`Pesquise a jurisprudência mais relevante para o caso:\n\n${caso}`,
    preliminares:`Identifique preliminares processuais cabíveis:\n\n${caso}`
  };

  await callAI(SYSTEM_JURIDICO, prompts[currentArg], 'arg-output-text');
  showToast('Argumentos gerados!','success');
}

/* ──────────── PESQUISA ──────────── */
async function runPesquisa(){
  const tema = document.getElementById('pesquisa-input')?.value || '';
  const tribunal = document.getElementById('pesquisa-tribunal')?.value || '';

  if(!tema.trim()){
    showToast('Digite um tema de pesquisa.','error');
    return;
  }

  const prompts = {
    jurisprudencia_stj:`Pesquise a jurisprudência mais importante sobre: "${tema}". ${tribunal ? 'Tribunais: ' + tribunal + '.' : ''}`,
    legislacao:`Apresente a legislação aplicável ao tema: "${tema}". ${tribunal ? 'Jurisdição: ' + tribunal + '.' : ''}`,
    doutrina:`Apresente o posicionamento doutrinário dominante sobre: "${tema}". ${tribunal ? 'Contexto: ' + tribunal + '.' : ''}`,
    prazo_prescricao:`Analise os prazos aplicáveis ao tema: "${tema}". ${tribunal ? 'Tribunal: ' + tribunal + '.' : ''}`
  };

  await callAI(SYSTEM_JURIDICO, prompts[currentPesquisa], 'pesquisa-output-text');
  showToast('Pesquisa concluída!','success');
}

/* ──────────── CHAT ──────────── */
const chatHistory = [];

async function sendChat(){
  const inp = document.getElementById('chat-input');
  const msg = inp?.value.trim();

  if(!msg) return;

  inp.value = '';
  const msgs = document.getElementById('chat-messages');
  if(!msgs) return;

  msgs.innerHTML += `
    <div class="chat-msg user">
      <div class="chat-avatar user">L</div>
      <div class="chat-bubble">${msg}</div>
    </div>
  `;

  const thinking = document.createElement('div');
  thinking.className = 'chat-msg';
  thinking.innerHTML = `
    <div class="chat-avatar ai">L</div>
    <div class="chat-bubble thinking">
      <div class="dots"><span></span><span></span><span></span></div>
    </div>
  `;
  msgs.appendChild(thinking);
  msgs.scrollTop = msgs.scrollHeight;

  chatHistory.push({role:'user', content:msg});

  await new Promise(resolve => setTimeout(resolve, 1000));

  const texto = msg.toLowerCase();
  let resposta = '';

  if (texto.includes('divórcio') || texto.includes('divorcio')) {
    resposta = `Em casos de divórcio, normalmente analisa-se:

• regime de bens
• guarda dos filhos
• alimentos
• partilha patrimonial
• eventual uso de imóvel comum

⚠️ Resposta simulada para demonstração do protótipo.`;
  } else if (texto.includes('trabalhista')) {
    resposta = `Em matéria trabalhista, os principais pontos costumam ser:

• vínculo empregatício
• horas extras
• verbas rescisórias
• FGTS
• adicional e eventuais nulidades

⚠️ Resposta ilustrativa do protótipo.`;
  } else if (texto.includes('contrato')) {
    resposta = `Na análise contratual, os pontos principais são:

• objeto do contrato
• obrigações das partes
• multa e penalidades
• cláusula de rescisão
• prazo
• foro competente

⚠️ Resposta simulada para protótipo.`;
  } else if (texto.includes('crime') || texto.includes('penal')) {
    resposta = `Em um cenário penal, normalmente verifica-se:

• tipificação da conduta
• materialidade
• autoria
• nulidades processuais
• estratégia defensiva

⚠️ Esta resposta é apenas demonstrativa.`;
  } else {
    resposta = `Entendi sua dúvida jurídica.

Como protótipo, este assistente pode simular análises sobre:
• contratos
• direito de família
• trabalhista
• penal
• peças processuais
• resumos e argumentos

⚠️ Resposta gerada em modo demonstração.`;
  }

  chatHistory.push({role:'assistant', content:resposta});

  thinking.remove();
  msgs.innerHTML += `
    <div class="chat-msg">
      <div class="chat-avatar ai">L</div>
      <div class="chat-bubble">${resposta.replace(/\n/g,'<br>')}</div>
    </div>
  `;
  msgs.scrollTop = msgs.scrollHeight;
}

/* ──────────── UTILS ──────────── */
function copyOutput(id){
  const el = document.getElementById(id);
  const t = el ? el.textContent : '';
  if(!t){
    showToast('Nada para copiar.','error');
    return;
  }

  navigator.clipboard.writeText(t)
    .then(()=>showToast('Texto copiado!','success'))
    .catch(()=>showToast('Erro ao copiar.','error'));
}

function downloadText(id, filename){
  const el = document.getElementById(id);
  const t = el ? el.textContent : '';
  if(!t){
    showToast('Nada para baixar.','error');
    return;
  }

  const a = document.createElement('a');
  a.href = 'data:text/plain;charset=utf-8,' + encodeURIComponent(t);
  a.download = filename;
  a.click();
  showToast('Download iniciado!','success');
}

/* ──────────── CALENDAR ──────────── */
function buildCalendar(){
  const cal = document.getElementById('calendar');
  if(!cal || cal.children.length > 0) return;

  const events = [16,18,22,25,28];
  const firstDay = 6;
  const days = 31;

  for(let i=0; i<firstDay; i++) cal.innerHTML += '<div></div>';

  for(let d=1; d<=days; d++){
    const cls = d===14 ? 'today' : events.includes(d) ? 'event' : '';
    cal.innerHTML += `<div class="cal-day ${cls}">${d}</div>`;
  }
}

/* ──────────── CHARTS ──────────── */
function buildCharts(){
  const bar = document.getElementById('chart-bar');
  if(!bar || bar.children.length > 0) return;

  const data = [
    {m:'Out',v:4},
    {m:'Nov',v:6},
    {m:'Dez',v:3},
    {m:'Jan',v:5},
    {m:'Fev',v:7},
    {m:'Mar',v:5}
  ];

  const max = Math.max(...data.map(d=>d.v));
  const colors = ['#8A7040','#8A7040','#8A7040','#B8975A','#C4A35A','#D4B580'];
  const labels = document.getElementById('chart-labels');

  data.forEach((d,i)=>{
    const h = Math.round((d.v/max)*100);
    bar.innerHTML += `<div class="chart-bar" style="height:${h}%;background:${colors[i]};min-height:12px" title="${d.v} processos"></div>`;
    if(labels){
      labels.innerHTML += `<div class="chart-bar-label" style="flex:1;font-size:10px;color:var(--text-muted);text-align:center">${d.m}<br><strong style="color:var(--text)">${d.v}</strong></div>`;
    }
  });

  const area = document.getElementById('chart-area');
  if(!area) return;

  const areas = [
    {l:'Trabalhista',v:38,c:'#4A8C5C'},
    {l:'Cível',v:24,c:'#B8975A'},
    {l:'Consumidor',v:20,c:'#2A5C8C'},
    {l:'Empresarial',v:12,c:'#8C3A3A'},
    {l:'Família',v:6,c:'#7A6AAE'}
  ];

  area.innerHTML = '';
  areas.forEach(a=>{
    area.innerHTML += `
      <div style="margin-bottom:12px">
        <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text-muted);margin-bottom:4px">
          <span>${a.l}</span><span>${a.v}%</span>
        </div>
        <div class="progress">
          <div class="progress-fill" style="width:${a.v}%;background:${a.c}"></div>
        </div>
      </div>
    `;
  });
}

/* ──────────── INIT ──────────── */
document.addEventListener('DOMContentLoaded', () => {
  showPage('dashboard', null);
});
</script>
