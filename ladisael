/* ──────────── IA DEMO (PROTÓTIPO) ──────────── */
const SYSTEM_JURIDICO = `Você é um advogado sênior altamente qualificado do escritório Ladisael Advocacia, com mais de 20 anos de experiência no direito brasileiro. Seus textos são precisos, formais, técnicos e fundamentados na legislação e jurisprudência vigente. Responda sempre em português, de forma profissional. Máximo 600 palavras por resposta, mas seja completo e útil.`;

function fakeAIResponse(userMessage, outputId=''){
  const texto = (userMessage || '').toLowerCase();

  if (outputId.includes('red-output-text')) {
    if (texto.includes('contrato')) {
      return `MINUTA INICIAL (PROTÓTIPO)

CLÁUSULA 1 – OBJETO
O presente instrumento tem por objeto disciplinar a relação jurídica entre as partes, nos termos ajustados.

CLÁUSULA 2 – OBRIGAÇÕES
As partes obrigam-se ao fiel cumprimento das disposições contratuais, observando boa-fé, equilíbrio e função social do contrato.

CLÁUSULA 3 – PRAZO E RESCISÃO
O prazo de vigência será o ajustado entre as partes, podendo haver rescisão por inadimplemento ou comum acordo.

CLÁUSULA 4 – FORO
Fica eleito o foro competente para dirimir controvérsias.

⚠️ Conteúdo demonstrativo de protótipo.`;
    }

    return `EXCELENTÍSSIMO SENHOR DOUTOR JUIZ DE DIREITO

A parte autora, por intermédio de seu advogado, vem respeitosamente à presença de Vossa Excelência apresentar a presente peça processual, com fundamento nos fatos e no direito aplicável.

I – DOS FATOS
Os fatos narrados indicam possível violação de direito subjetivo da parte requerente.

II – DO DIREITO
Há plausibilidade jurídica inicial, com necessidade de adequada instrução e fundamentação normativa.

III – DOS PEDIDOS
a) recebimento da peça;
b) citação/intimação da parte contrária;
c) procedência dos pedidos;
d) demais cominações legais.

⚠️ Modelo gerado em modo demonstração.`;
  }

  if (outputId.includes('analise-output-text')) {
    if (texto.includes('contrato') || texto.includes('cláusula') || texto.includes('clausula')) {
      return `ANÁLISE PRELIMINAR (PROTÓTIPO)

1. Tipo do documento:
Contrato/Instrumento obrigacional.

2. Pontos de atenção:
• cláusulas de multa
• cláusula de rescisão
• distribuição de responsabilidades
• foro de eleição
• prazos e penalidades

3. Riscos identificados:
• possível desequilíbrio contratual
• redação ambígua em obrigações
• sanções potencialmente excessivas

4. Recomendação:
Revisão jurídica integral antes da assinatura.`;
    }

    return `RESUMO EXECUTIVO (PROTÓTIPO)

1. Partes envolvidas:
Identificação pendente de conferência documental.

2. Objeto:
Há controvérsia jurídica com potencial litigioso.

3. Pontos críticos:
• cronologia dos fatos
• provas documentais
• competência
• prazo prescricional/decadencial

4. Estratégia inicial:
Organizar documentos, delimitar tese e avaliar risco processual.`;
  }

  if (outputId.includes('arg-output-text')) {
    return `ARGUMENTOS JURÍDICOS (PROTÓTIPO)

1. Boa-fé objetiva e função social da relação jurídica.
2. Interpretação sistemática da legislação aplicável.
3. Princípio da proporcionalidade e vedação ao abuso de direito.
4. Prevalência da prova documental e coerência fática.
5. Jurisprudência favorável a teses de proteção da parte vulnerável.

⚠️ Resultado demonstrativo para apresentação do sistema.`;
  }

  if (outputId.includes('pesquisa-output-text')) {
    return `PESQUISA LEGAL (PROTÓTIPO)

• Jurisprudência: recomenda-se consulta a precedentes dos tribunais superiores sobre o tema.
• Legislação: identificar artigos específicos do CPC, CC, CDC, CLT ou legislação especial.
• Doutrina: mapear corrente majoritária e minoritária.
• Prazos: verificar prescrição, decadência e marcos interruptivos/suspensivos.

⚠️ Este conteúdo é simulado para fins de demonstração visual.`;
  }

  return `RESULTADO DA ANÁLISE (PROTÓTIPO)

• Foram identificados pontos jurídicos relevantes.
• Há fundamentos plausíveis para desenvolvimento técnico.
• Recomenda-se revisão profissional antes de qualquer uso real.

⚠️ Resposta simulada para apresentação do protótipo.`;
}

async function callAI(systemPrompt, userMessage, outputId) {
  const el = document.getElementById(outputId);
  if(!el) return '';

  el.innerHTML = '<div class="thinking"><div class="dots"><span></span><span></span><span></span></div> Analisando com IA jurídica...</div>';

  await new Promise(resolve => setTimeout(resolve, 1200));

  const text = fakeAIResponse(userMessage, outputId);
  el.textContent = text;
  return text;
}

/* ──────────── REDAÇÃO ──────────── */
async function runRedacao(){
  const tipo = document.getElementById('red-tipo')?.value || '';
  const partes = document.getElementById('red-partes')?.value || '';
  const fatos = document.getElementById('red-fatos')?.value || '';
  const pedidos = document.getElementById('red-pedidos')?.value || '';

  if(!fatos.trim()){
    showToast('Descreva os fatos do caso.','error');
    return;
  }

  const prompts = {
    peticao:`Redija uma petição inicial completa. Tipo: ${tipo}. Partes: ${partes}. Fatos: ${fatos}. Pedidos: ${pedidos}.`,
    contestacao:`Redija uma contestação completa. Tipo: ${tipo}. Partes: ${partes}. Fatos: ${fatos}. Tese defensiva: ${pedidos}.`,
    recurso:`Redija as razões de recurso/apelação. Ação: ${tipo}. Partes: ${partes}. Fatos: ${fatos}. Fundamentos: ${pedidos}.`,
    contrato:`Elabore as cláusulas principais do contrato solicitado. Tipo: ${tipo}. Partes: ${partes}. Condições: ${fatos}. Especificidades: ${pedidos}.`,
    notificacao:`Redija uma notificação extrajudicial. Situação: ${fatos}. Partes: ${partes}. Exigência: ${pedidos}.`,
    parecer:`Elabore um parecer jurídico. Questão: ${fatos}. Contexto: ${partes}. Foco: ${pedidos}.`,
    acordo:`Redija minuta de acordo. Contexto: ${fatos}. Partes: ${partes}. Termos: ${pedidos}.`,
    habeas:`Redija o instrumento constitucional cabível. Situação: ${fatos}. Partes: ${partes}. Pedido: ${pedidos}.`,
    embargo:`Redija embargos/impugnação. Decisão embargada: ${fatos}. Partes: ${partes}. Pontos: ${pedidos}.`
  };

  await callAI(SYSTEM_JURIDICO, prompts[currentTool] || prompts.peticao, 'red-output-text');
  showToast('Peça gerada com sucesso!','success');
}

/* ──────────── ANÁLISE ──────────── */
async function runAnalise(){
  const texto = document.getElementById('analise-input')?.value || '';
  const foco = document.getElementById('analise-foco')?.value || '';

  if(!texto.trim()){
    showToast('Cole um texto para análise.','error');
    return;
  }

  const prompts = {
    resumo_proc:`Resumo executivo. ${foco ? 'Foco: ' + foco + '.' : ''}\n\nTexto:\n${texto}`,
    resumo_doc:`Análise de documento. ${foco ? 'Foco: ' + foco + '.' : ''}\n\nDocumento:\n${texto}`,
    risco:`Análise de risco processual. ${foco ? 'Foco: ' + foco + '.' : ''}\n\nCaso:\n${texto}`,
    clausulas:`Identifique cláusulas problemáticas. ${foco ? 'Foco: ' + foco + '.' : ''}\n\nTexto:\n${texto}`
  };

  await callAI(SYSTEM_JURIDICO, prompts[currentAnalise], 'analise-output-text');
  showToast('Análise concluída!','success');
}

/* ──────────── ARGUMENTOS ──────────── */
async function runArgumentos(){
  const area = document.getElementById('arg-area')?.value || '';
  const posicao = document.getElementById('arg-posicao')?.value || '';
  const caso = document.getElementById('arg-caso')?.value || '';

  if(!caso.trim()){
    showToast('Descreva o caso.','error');
